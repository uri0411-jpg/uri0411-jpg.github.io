{
  "color": {
    "purple": {
      "700": { "$type": "color", "$value": "#2D1B69" },
      "900": { "$type": "color", "$value": "#110B2E" },
      "950": { "$type": "color", "$value": "#0A0619" }
    },
    "pink": {
      "500": { "$type": "color", "$value": "#EC4899" }
    },
    "orange": {
      "400": { "$type": "color", "$value": "#FB923C" },
      "500": { "$type": "color", "$value": "#F97316" },
      "800": { "$type": "color", "$value": "#7A3E00" },
      "900": { "$type": "color", "$value": "#5A2D0C" }
    },
    "amber": {
      "300": { "$type": "color", "$value": "#FCD34D" },
      "400": { "$type": "color", "$value": "#F0B84A" },
      "500": { "$type": "color", "$value": "#F59E0B" }
    },
    "neutral": {
      "50":  { "$type": "color", "$value": "#F5E6C8" },
      "200": { "$type": "color", "$value": "#C49A6C" },
      "700": { "$type": "color", "$value": "#6B3A0E" },
      "800": { "$type": "color", "$value": "#5A2D0C" },
      "850": { "$type": "color", "$value": "#3B1F08" },
      "900": { "$type": "color", "$value": "#2A1505" },
      "950": { "$type": "color", "$value": "#1A0E06" }
    },
    "blue": {
      "400": { "$type": "color", "$value": "#7090C8" }
    },
    "green": {
      "500": { "$type": "color", "$value": "#3CA03C" }
    },
    "red": {
      "500": { "$type": "color", "$value": "#DC2828" },
      "700": { "$type": "color", "$value": "#CC0000" }
    }
  },
  "radius": {
    "sm":   { "$type": "dimension", "$value": "6px" },
    "md":   { "$type": "dimension", "$value": "10px" },
    "lg":   { "$type": "dimension", "$value": "18px" },
    "pill": { "$type": "dimension", "$value": "50px" }
  },
  "blur": {
    "sm":  { "$type": "dimension", "$value": "8px" },
    "md":  { "$type": "dimension", "$value": "12px" },
    "lg":  { "$type": "dimension", "$value": "20px" },
    "xl":  { "$type": "dimension", "$value": "32px" }
  },
  "luminance": {
    "sky":   { "$type": "number", "$value": 0.95 },
    "atmos": { "$type": "number", "$value": 1 },
    "glass": { "$type": "number", "$value": 1.05 },
    "ui":    { "$type": "number", "$value": 1.1 }
  },
  "motion": {
    "duration": {
      "fast":   { "$type": "string", "$value": "120ms" },
      "medium": { "$type": "string", "$value": "240ms" },
      "slow":   { "$type": "string", "$value": "600ms" }
    },
    "ease": {
      "standard": { "$type": "string", "$value": "cubic-bezier(0.4,0,0.2,1)" },
      "spring":   { "$type": "string", "$value": "cubic-bezier(0.34,1.56,0.64,1)" },
      "out":      { "$type": "string", "$value": "cubic-bezier(0.22,1,0.36,1)" }
    }
  },
  "shadow": {
    "inset": {
      "highlight-top":    { "$type": "string", "$value": "inset 0 1px 0 rgba(255,255,255,0.20)" },
      "highlight-bottom": { "$type": "string", "$value": "inset 0 -1px 0 rgba(0,0,0,0.15)" },
      "glow-rim":         { "$type": "string", "$value": "inset 0 0 0 1px rgba(255,255,255,0.10)" }
    }
  },
  "letter-spacing": {
    "tight":  { "$type": "string", "$value": "-0.02em" },
    "hero":   { "$type": "string", "$value": "-0.04em" },
    "normal": { "$type": "string", "$value": "0" },
    "wide":   { "$type": "string", "$value": "0.05em" }
  },
  "font": {
    "family": {
      "title":   { "$type": "fontFamily", "$value": "'Assistant', 'Rubik', 'Heebo', sans-serif" },
      "body":    { "$type": "fontFamily", "$value": "'Assistant', 'Rubik', 'Heebo', sans-serif" },
      "spot":    { "$type": "fontFamily", "$value": "'Playfair Display', serif" }
    },
    "size": {
      "xs":      { "$type": "dimension", "$value": "9px" },
      "sm":      { "$type": "dimension", "$value": "10px" },
      "md":      { "$type": "dimension", "$value": "12px" },
      "lg":      { "$type": "dimension", "$value": "14px" },
      "xl":      { "$type": "dimension", "$value": "16px" },
      "heading": { "$type": "dimension", "$value": "18px" },
      "display": { "$type": "dimension", "$value": "24px" },
      "hero":    { "$type": "dimension", "$value": "64px" }
    },
    "weight": {
      "light":     { "$type": "number", "$value": 300 },
      "regular":   { "$type": "number", "$value": 400 },
      "medium":    { "$type": "number", "$value": 500 },
      "semibold":  { "$type": "number", "$value": 600 },
      "bold":      { "$type": "number", "$value": 700 },
      "extrabold": { "$type": "number", "$value": 800 },
      "black":     { "$type": "number", "$value": 900 },
      "hero":      { "$type": "number", "$value": 300 },
      "ui":        { "$type": "number", "$value": 500 },
      "emphasis":  { "$type": "number", "$value": 700 }
    },
    "leading": {
      "tight":   { "$type": "number", "$value": 1.0 },
      "normal":  { "$type": "number", "$value": 1.4 },
      "relaxed": { "$type": "number", "$value": 1.6 }
    }
  }
}
