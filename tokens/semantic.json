    "score-up":   { "$type": "string", "$value": "height 240ms cubic-bezier(0.34,1.56,0.64,1)" },
    "score-down": { "$type": "string", "$value": "height 600ms cubic-bezier(0.22,1,0.36,1)" },
    "hover":      { "$type": "string", "$value": "transform 120ms cubic-bezier(0.4,0,0.2,1), opacity 120ms cubic-bezier(0.4,0,0.2,1)" },
    "screen":     { "$type": "string", "$value": "opacity 600ms cubic-bezier(0.4,0,0.2,1)" }
  },
  "radius": {
    "card":  { "$type": "dimension", "$value": "18px" },
