  "font": {
    "title": { "$type": "fontFamily", "$value": "'Assistant', 'Rubik', 'Heebo', sans-serif" },
    "body":  { "$type": "fontFamily", "$value": "'Assistant', 'Rubik', 'Heebo', sans-serif" },
    "spot":  { "$type": "fontFamily", "$value": "'Playfair Display', serif" }
  }
