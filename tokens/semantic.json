      "glass":        { "$type": "color", "$value": "rgba(20, 10, 4, 0.55)" },
      "glass-border": { "$type": "color", "$value": "rgba(212, 165, 116, 0.18)" }
    },
    "text": {
      "primary":   { "$type": "color", "$value": "#F5E6C8" },
      "secondary": { "$type": "color", "$value": "rgba(245, 230, 200, 0.75)" },
