      "edge-highlight": { "$type": "color", "$value": "rgba(255, 255, 255, 0.80)" }
    }
  },
  "layer": {
    "sky":     { "$type": "number", "$value": 0 },
    "atmos":   { "$type": "number", "$value": 1 },
