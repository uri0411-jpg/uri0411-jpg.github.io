{
  "$description": "Night vision mode overrides — applied via body.night-vision selector",
  "color": {
    "surface": {
      "app":          { "$type": "color", "$value": "#0A0604" },
      "glass":        { "$type": "color", "$value": "rgba(8, 3, 1, 0.76)" },
      "glass-border": { "$type": "color", "$value": "rgba(120, 80, 40, 0.12)" }
    },
    "text": {
      "primary":   { "$type": "color", "$value": "rgba(245, 220, 180, 0.52)" },
      "secondary": { "$type": "color", "$value": "rgba(245, 220, 180, 0.38)" },
      "tertiary":  { "$type": "color", "$value": "rgba(245, 220, 180, 0.25)" }
    },
    "accent": {
      "primary":       { "$type": "color", "$value": "#7A3E00" },
      "primary-light": { "$type": "color", "$value": "#9B5200" },
      "gradient-top":  { "$type": "color", "$value": "#110B2E" },
      "gradient-bot":  { "$type": "color", "$value": "#5A2D0C" }
    }
  }
}
